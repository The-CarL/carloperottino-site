---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';
import { getReadingTime } from '../../lib/reading-time';
import type { BlogPost } from '../../lib/posts';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const readingTime = post.body ? getReadingTime(post.body) : '';
---

<article class="group border-b border-surface-3/50 py-8 first:pt-0 last:border-b-0">
  <a href={`/blog/${post.id}`} class="block">
    <h3 class="text-xl font-semibold text-cream group-hover:text-accent transition-colors duration-200">
      {post.data.title}
    </h3>
    <div class="flex items-center gap-3 mt-2 text-sm text-warm-dim">
      <FormattedDate date={post.data.date} />
      {readingTime && (
        <>
          <span class="text-surface-3">&middot;</span>
          <span>{readingTime}</span>
        </>
      )}
    </div>
    <p class="mt-3 text-warm-gray leading-relaxed">
      {post.data.description}
    </p>
  </a>
  {post.data.tags.length > 0 && (
    <TagList tags={post.data.tags} class="mt-4" />
  )}
</article>
