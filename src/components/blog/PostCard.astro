---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';
import { getReadingTime } from '../../lib/reading-time';
import type { BlogPost } from '../../lib/posts';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const readingTime = post.body ? getReadingTime(post.body) : '';
---

<article class="group rounded-xl border border-surface-3/50 bg-surface-2/30 p-6 transition-all duration-300 hover:border-accent/20 hover:bg-surface-2/50">
  <a href={`/blog/${post.id}`} class="block">
    <div class="flex items-center gap-3 text-sm text-warm-dim mb-3">
      <FormattedDate date={post.data.date} />
      {readingTime && (
        <>
          <span class="text-surface-3">&middot;</span>
          <span>{readingTime}</span>
        </>
      )}
    </div>
    <h3 class="text-lg font-semibold text-cream group-hover:text-accent transition-colors duration-200 leading-snug">
      {post.data.title}
    </h3>
    <p class="mt-2 text-sm text-warm-gray leading-relaxed line-clamp-3">
      {post.data.description}
    </p>
  </a>
  {post.data.tags.length > 0 && (
    <TagList tags={post.data.tags} class="mt-4" />
  )}
</article>
