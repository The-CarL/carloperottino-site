---
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-surface/80 backdrop-blur-xl border-b border-surface-3/50">
  <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="/"
      class="text-accent font-semibold text-lg tracking-[0.15em] hover:text-accent-light transition-colors"
    >
      CP
    </a>
    <div class="flex items-center gap-6">
      <a
        href="/blog"
        class:list={[
          'text-sm tracking-wide transition-colors',
          currentPath === '/blog' || currentPath === '/blog/'
            ? 'text-accent'
            : 'text-warm-gray hover:text-cream',
        ]}
      >
        Blog
      </a>
      <a
        href="/blog/tags"
        class:list={[
          'text-sm tracking-wide transition-colors',
          currentPath.startsWith('/blog/tags')
            ? 'text-accent'
            : 'text-warm-gray hover:text-cream',
        ]}
      >
        Tags
      </a>
      <a
        href="/rss.xml"
        class="text-warm-gray hover:text-accent transition-colors"
        aria-label="RSS Feed"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36zM4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44zm0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93v-2.83z"/>
        </svg>
      </a>
    </div>
  </div>
</nav>
