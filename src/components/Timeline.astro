<section id="experience" class="py-24 px-6">
  <div class="max-w-3xl mx-auto">
    <!-- Section heading -->
    <h2 class="font-mono text-xs tracking-[0.25em] uppercase text-accent mb-12">Experience</h2>

    <!-- Timeline entries -->
    <div class="flex flex-col gap-4">
      {chapters.map((ch) => (
        <div class="timeline-entry group" data-entry={ch.id}>
          <!-- Clickable header -->
          <button
            class="timeline-header w-full text-left flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 p-5 rounded-xl border border-overlay/5 bg-overlay/[0.02] hover:border-accent/20 hover:bg-accent/[0.03] transition-all duration-300 cursor-pointer"
            data-toggle={ch.id}
          >
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <span class="font-mono text-[0.65rem] font-medium text-accent tracking-[0.1em] bg-accent/10 border border-accent/20 w-11 h-11 rounded-lg flex items-center justify-center shrink-0">
                {ch.abbrev}
              </span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="text-[0.95rem] font-semibold text-cream">{ch.company}</h3>
                  {ch.label && (
                    <span class="text-[0.65rem] tracking-[0.15em] uppercase text-accent border border-accent/35 px-2.5 py-0.5 rounded-full font-medium">
                      {ch.label}
                    </span>
                  )}
                </div>
                <p class="text-[0.8rem] text-warm-dim mt-0.5 truncate">{ch.role}</p>
              </div>
            </div>
            <div class="flex items-center gap-3 sm:gap-4 mt-1 sm:mt-0 pl-14 sm:pl-0">
              <span class="font-mono text-[0.72rem] text-warm-dim whitespace-nowrap">{ch.period}</span>
              <svg class="chevron-icon w-4 h-4 text-warm-dim shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </div>
          </button>

          <!-- Expandable detail -->
          <div class="timeline-detail overflow-hidden transition-all duration-400 ease-out" data-detail={ch.id}>
            <div class="px-5 pb-5 pt-3">
              <!-- Location & focus -->
              <p class="text-[0.82rem] text-warm-dim mb-4">
                {ch.location}{ch.focus && <span> &middot; {ch.focus}</span>}
              </p>

              <!-- Impact -->
              {ch.impactNumber && (
                <div class="flex items-baseline gap-3 px-5 py-4 bg-accent/[0.04] border border-accent/10 rounded-xl mb-5">
                  <span class="text-2xl font-extrabold text-accent tracking-tight leading-none">{ch.impactNumber}</span>
                  <span class="text-[0.85rem] text-warm-gray leading-snug">{ch.impactLabel}</span>
                </div>
              )}

              <!-- Highlights -->
              <div class="mb-5">
                <h4 class="text-[0.75rem] tracking-[0.2em] uppercase text-warm-dim font-semibold mb-3">Highlights</h4>
                <ul class="list-none p-0 m-0">
                  {ch.highlights.map((h) => (
                    <li class="flex gap-2.5 text-[0.875rem] text-warm-gray leading-relaxed mb-2">
                      <span class="text-accent shrink-0 mt-px font-bold">&rsaquo;</span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Key Projects -->
              {ch.projects.length > 0 && (
                <div class="mb-5">
                  <h4 class="text-[0.75rem] tracking-[0.2em] uppercase text-warm-dim font-semibold mb-3">Key Projects</h4>
                  <div class="flex flex-col gap-2.5">
                    {ch.projects.map((p) => (
                      <div class:list={[
                        'p-3.5 rounded-xl border transition-colors duration-300',
                        p.featured ? 'bg-accent/[0.05] border-accent/15' : 'bg-overlay/[0.02] border-overlay/[0.06] hover:border-accent/20'
                      ]}>
                        <div class="flex items-center justify-between gap-2">
                          <h5 class="text-[0.9rem] font-semibold text-cream">{p.title}</h5>
                          {p.featured && <span class="text-accent text-[0.85rem] shrink-0">&#9733;</span>}
                        </div>
                        <p class="text-[0.82rem] text-warm-gray leading-relaxed mt-1">{p.desc}</p>
                        {p.metric && <p class="font-mono text-[0.75rem] text-accent mt-1.5">{p.metric}</p>}
                      </div>
                    ))}
                  </div>
                </div>
              )}

              <!-- Technologies -->
              {ch.tech.length > 0 && (
                <div>
                  <h4 class="text-[0.75rem] tracking-[0.2em] uppercase text-warm-dim font-semibold mb-3">Technologies</h4>
                  <div class="flex flex-wrap gap-1.5">
                    {ch.tech.map((t) => (
                      <span class="px-3 py-1 bg-overlay/[0.03] border border-overlay/[0.08] rounded-full text-[0.75rem] text-warm-gray">{t}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Earlier Roles -->
    <div class="mt-10">
      <h3 class="text-[0.75rem] tracking-[0.2em] uppercase text-warm-dim font-semibold mb-4">Earlier Experience</h3>
      <div class="flex flex-col gap-3">
        {earlierRoles.map((role) => (
          <div class="flex flex-col gap-0.5">
            <span class="text-[0.9rem] font-medium text-cream">{role.company}</span>
            <span class="text-[0.82rem] text-warm-gray">{role.role}</span>
            <span class="text-[0.78rem] text-warm-dim">{role.location} &middot; {role.period}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Skills & Expertise -->
    <div class="mt-14">
      <h3 class="text-[0.75rem] tracking-[0.2em] uppercase text-warm-dim font-semibold mb-5">Skills & Expertise</h3>
      <div class="flex flex-col gap-4">
        {skills.map((group) => (
          <div>
            <h4 class="text-[0.8rem] font-semibold text-cream/80 mb-2">{group.title}</h4>
            <div class="flex flex-wrap gap-1.5">
              {group.items.map((item) => (
                <span class="px-2.5 py-0.5 bg-accent/[0.05] border border-accent/15 rounded-full text-[0.72rem] text-warm-gray">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-detail {
    max-height: 0;
    opacity: 0;
  }

  .timeline-detail.expanded {
    max-height: 3000px;
    opacity: 1;
  }

  .timeline-entry .chevron-icon {
    transition: transform 0.3s ease;
  }

  .timeline-entry.open .chevron-icon {
    transform: rotate(180deg);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.toggle;
      if (!id) return;

      const entry = btn.closest('.timeline-entry');
      const detail = document.querySelector<HTMLElement>(`[data-detail="${id}"]`);
      if (!entry || !detail) return;

      const isOpen = entry.classList.contains('open');

      // Close all other entries
      document.querySelectorAll('.timeline-entry.open').forEach((openEntry) => {
        if (openEntry !== entry) {
          openEntry.classList.remove('open');
          const openDetail = openEntry.querySelector<HTMLElement>('.timeline-detail');
          if (openDetail) openDetail.classList.remove('expanded');
        }
      });

      // Toggle current
      if (isOpen) {
        entry.classList.remove('open');
        detail.classList.remove('expanded');
      } else {
        entry.classList.add('open');
        detail.classList.add('expanded');
      }
    });
  });
</script>
