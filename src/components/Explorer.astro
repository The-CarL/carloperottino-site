</style>

<script>
  // ─── State ───
  let activePanel: string | null = null;

  // ─── Elements ───
  const overlay = document.getElementById('panel-overlay');
  const backdrop = document.getElementById('panel-backdrop');
  const closeBtn = document.getElementById('panel-close');
  const prompt = document.getElementById('constellation-prompt');
  const constellation = document.getElementById('constellation');
  const particleCanvas = document.getElementById('particle-canvas') as HTMLCanvasElement | null;
  const linesSvg = document.getElementById('lines-svg');

  // ─── Open / Close Panel ───
  function openPanel(id: string) {
    if (activePanel === id) {
      closePanel();
      return;
    }
    activePanel = id;

    overlay?.classList.add('open');
    prompt?.classList.add('hidden');
    document.body.style.overflow = 'hidden';

    // Switch active panel view
    document.querySelectorAll('.panel-view').forEach((el) => el.classList.remove('active'));
    document.querySelector(`.panel-view[data-panel="${id}"]`)?.classList.add('active');

    // Update node states
    document.querySelectorAll('.c-node').forEach((node) => {
      const nodeId = (node as HTMLElement).dataset.id;
      node.classList.toggle('selected', nodeId === id);
      node.classList.toggle('dimmed', nodeId !== id && nodeId !== 'overview');
    });

    // Update lines
    updateLines(id);

    // Scroll panel to top
    const scroll = document.querySelector('.detail-panel__scroll');
    if (scroll) scroll.scrollTop = 0;
  }

  function closePanel() {
    activePanel = null;
    overlay?.classList.remove('open');
    prompt?.classList.remove('hidden');
    document.body.style.overflow = '';

    document.querySelectorAll('.c-node').forEach((node) => {
      node.classList.remove('selected', 'dimmed');
    });

    document.querySelectorAll('.panel-view').forEach((el) => el.classList.remove('active'));
    resetLines();
  }

  // ─── Event Listeners ───
  document.querySelectorAll('.c-node').forEach((node) => {
    node.addEventListener('click', () => {
      const id = (node as HTMLElement).dataset.id;
      if (id) openPanel(id);
    });
  });

  document.querySelectorAll('.mobile-card').forEach((card) => {
    card.addEventListener('click', () => {
      const id = (card as HTMLElement).dataset.id;
      if (id) openPanel(id);
    });
  });

  closeBtn?.addEventListener('click', closePanel);
  backdrop?.addEventListener('click', closePanel);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && activePanel) closePanel();
  });

  // ─── SVG Connection Lines ───
  const connectionDefs = [
    { from: 'overview', to: 'aws' },
    { from: 'overview', to: 'perspectv' },
    { from: 'overview', to: 'ey' },
    { from: 'overview', to: 'ge' },
    { from: 'overview', to: 'bmw' },
    { from: 'overview', to: 'education' },
  ];

  function getNodeCenter(id: string): { x: number; y: number } | null {
    const node = document.querySelector(`.c-node[data-id="${id}"]`) as HTMLElement | null;
    if (!node || !constellation) return null;
    const circle = node.querySelector('.c-node__circle') as HTMLElement | null;
    const el = circle || node;
    const cRect = constellation.getBoundingClientRect();
    const elRect = el.getBoundingClientRect();
    return {
      x: elRect.left + elRect.width / 2 - cRect.left,
      y: elRect.top + elRect.height / 2 - cRect.top,
    };
  }

  function drawLines() {
    if (!linesSvg) return;
    linesSvg.innerHTML = '';

    connectionDefs.forEach((conn) => {
      const from = getNodeCenter(conn.from);
      const to = getNodeCenter(conn.to);
      if (!from || !to) return;

      // Shorten lines so they stop at the circle edge
      const dx = to.x - from.x;
      const dy = to.y - from.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist === 0) return;

      const fromNode = document.querySelector(`.c-node[data-id="${conn.from}"] .c-node__circle`) as HTMLElement | null;
      const toNode = document.querySelector(`.c-node[data-id="${conn.to}"] .c-node__circle`) as HTMLElement | null;
      const fromR = fromNode ? fromNode.offsetWidth / 2 + 8 : 40;
      const toR = toNode ? toNode.offsetWidth / 2 + 8 : 40;

      const ux = dx / dist;
      const uy = dy / dist;

      const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      line.setAttribute('x1', String(from.x + ux * fromR));
      line.setAttribute('y1', String(from.y + uy * fromR));
      line.setAttribute('x2', String(to.x - ux * toR));
      line.setAttribute('y2', String(to.y - uy * toR));
      line.dataset.from = conn.from;
      line.dataset.to = conn.to;
      linesSvg.appendChild(line);
    });
  }

  function updateLines(activeId: string) {
    linesSvg?.querySelectorAll('line').forEach((line) => {
      const { from, to } = line.dataset;
      const isActive = from === activeId || to === activeId;
      line.classList.toggle('line-active', isActive);
      line.classList.toggle('line-dimmed', !isActive);
    });
  }

  function resetLines() {
    linesSvg?.querySelectorAll('line').forEach((line) => {
      line.classList.remove('line-active', 'line-dimmed');
    });
  }

  // Draw on load and resize
  drawLines();
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      drawLines();
      if (activePanel) updateLines(activePanel);
    }, 100);
  });

  // ─── Particle Animation ───
  if (particleCanvas) {
    const ctx = particleCanvas.getContext('2d');
    const particles: Array<{
      x: number; y: number; vx: number; vy: number; r: number; o: number;
    }> = [];
    let animId = 0;

    function resizeCanvas() {
      if (!particleCanvas) return;
      particleCanvas.width = particleCanvas.offsetWidth;
      particleCanvas.height = particleCanvas.offsetHeight;
    }

    function initParticles() {
      if (!particleCanvas) return;
      particles.length = 0;
      const count = Math.min(50, Math.floor((particleCanvas.width * particleCanvas.height) / 25000));
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * particleCanvas.width,
          y: Math.random() * particleCanvas.height,
          vx: (Math.random() - 0.5) * 0.25,
          vy: (Math.random() - 0.5) * 0.25,
          r: Math.random() * 1.2 + 0.4,
          o: Math.random() * 0.2 + 0.05,
        });
      }
    }

    function animate() {
      if (!ctx || !particleCanvas) return;
      ctx.clearRect(0, 0, particleCanvas.width, particleCanvas.height);

      particles.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > particleCanvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > particleCanvas.height) p.vy *= -1;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(201, 168, 108, ${p.o})`;
        ctx.fill();
      });

      animId = requestAnimationFrame(animate);
    }

    resizeCanvas();
    initParticles();
    animate();

    window.addEventListener('resize', () => {
      resizeCanvas();
      initParticles();
    });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cancelAnimationFrame(animId);
    }
  }
</script>
