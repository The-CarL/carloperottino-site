---

<section id="explorer" class="explorer-section">
  <!-- Particle canvas background -->
  <canvas id="particle-canvas" class="particle-canvas"></canvas>

  <!-- Constellation (desktop) -->
  <div class="constellation" id="constellation">
    <!-- SVG connections -->
    <svg id="lines-svg" class="lines-svg"></svg>

    <!-- Center node -->
    <button
      class="c-node c-node--center"
      data-id="overview"
      style={`left:${centerPos.x}%;top:${centerPos.y}%`}
    >
      <div class="c-node__circle">
        <span class="c-node__text">CP</span>
      </div>
    </button>

    <!-- Chapter nodes -->
    {chapters.map((ch) => (
      <button
        class:list={['c-node', 'c-node--chapter', ch.featured && 'c-node--featured']}
        data-id={ch.id}
        style={`left:${ch.pos.x}%;top:${ch.pos.y}%`}
      >
        <div class="c-node__circle">
          <span class="c-node__text">{ch.abbrev}</span>
        </div>
        <span class="c-node__label">{ch.company}</span>
        <span class="c-node__period">{ch.period}</span>
      </button>
    ))}

    <!-- Prompt -->
    <p class="constellation__prompt" id="constellation-prompt">
      Select a node to explore
    </p>
  </div>

  <!-- Mobile layout -->
  <div class="mobile-explorer" id="mobile-explorer">
    <p class="mobile-explorer__eyebrow">Experience</p>
    <h2 class="mobile-explorer__title">Explore My Journey</h2>
    {chapters.map((ch) => (
      <button class="mobile-card" data-id={ch.id}>
        <span class="mobile-card__abbrev">{ch.abbrev}</span>
        <div class="mobile-card__info">
          <h3 class="mobile-card__company">{ch.company}</h3>
          <p class="mobile-card__role">{ch.role}</p>
        </div>
        <span class="mobile-card__period">{ch.period}</span>
      </button>
    ))}
  </div>

  <!-- Panel overlay -->
  <div class="panel-overlay" id="panel-overlay">
    <div class="panel-backdrop" id="panel-backdrop"></div>
    <aside class="detail-panel" id="detail-panel">
      <button class="detail-panel__close" id="panel-close" aria-label="Close panel">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="detail-panel__scroll">
        <!-- ─── Overview panel ─── -->
        <div class="panel-view" data-panel="overview">
          <div class="pv-header">
            <p class="pv-eyebrow">About</p>
            <h2 class="pv-title">Carlo Perottino</h2>
            <p class="pv-subtitle">Technology Leader & Builder</p>
          </div>

          <p class="pv-desc">
            I build intelligent systems and lead high-performing teams at the intersection of AI,
            cloud infrastructure, and enterprise transformation. I've scaled teams across continents,
            shipped platforms used by thousands, and designed AI architectures from prototype to production
            — always focused on turning complex technical challenges into impactful products.
          </p>

          <div class="impact-grid">
            <div class="impact-item">
              <span class="impact-item__number">10+</span>
              <span class="impact-item__label">Years in Technology</span>
            </div>
            <div class="impact-item">
              <span class="impact-item__number">50+</span>
              <span class="impact-item__label">Team Members Led</span>
            </div>
            <div class="impact-item">
              <span class="impact-item__number">5</span>
              <span class="impact-item__label">Companies</span>
            </div>
            <div class="impact-item">
              <span class="impact-item__number">6</span>
              <span class="impact-item__label">Industries Served</span>
            </div>
          </div>

          <div class="pv-section">
            <h3 class="pv-section-title">Skills & Expertise</h3>
            {skills.map((group) => (
              <div class="skill-group">
                <h4 class="skill-group__title">{group.title}</h4>
                <div class="skill-group__tags">
                  {group.items.map((item) => (
                    <span class="skill-tag">{item}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <div class="pv-section">
            <h3 class="pv-section-title">Education</h3>
            <p class="text-base text-cream">University of Cincinnati</p>
            <p class="text-sm text-warm-gray mt-1">College of Engineering & Applied Science</p>
          </div>

          <div class="pv-section">
            <h3 class="pv-section-title">Certifications</h3>
            <p class="text-sm text-cream">AWS Certified Solutions Architect — Associate</p>
            <p class="text-sm text-cream">AWS Certified AI Practitioner</p>
            <p class="text-sm text-cream">AWS Certified Machine Learning Engineer — Associate</p>
          </div>

          <div class="pv-section">
            <h3 class="pv-section-title">Earlier Experience</h3>
            {earlierRoles.map((role) => (
              <div class="earlier-role">
                <span class="earlier-role__company">{role.company}</span>
                <span class="earlier-role__detail">{role.role}</span>
                <span class="earlier-role__meta">{role.location} · {role.period}</span>
              </div>
            ))}
          </div>

          <div class="pv-section pv-contact">
            <h3 class="pv-section-title">Contact</h3>
            <div class="contact-links">
              <a href="https://linkedin.com/in/carloperottino" target="_blank" rel="noopener noreferrer">LinkedIn</a>
              <a href="https://github.com/The-CarL" target="_blank" rel="noopener noreferrer">GitHub</a>
              <a href="mailto:carloperottino@gmail.com">carloperottino@gmail.com</a>
            </div>
          </div>
        </div>

        <!-- ─── Chapter panels ─── -->
        {chapters.map((ch) => (
          <div class="panel-view" data-panel={ch.id}>
            <div class="pv-header">
              <div class="pv-header-row">
                <p class="pv-eyebrow">{ch.period}</p>
                {ch.label && <span class="pv-badge">{ch.label}</span>}
              </div>
              <h2 class="pv-title">{ch.company}</h2>
              <p class="pv-subtitle">{ch.role}</p>
              <p class="pv-meta">
                {ch.location}{ch.focus && <span> &middot; {ch.focus}</span>}
              </p>
            </div>

            {ch.impactNumber && (
              <div class="impact-hero">
                <span class="impact-hero__number">{ch.impactNumber}</span>
                <span class="impact-hero__label">{ch.impactLabel}</span>
              </div>
            )}

            <div class="pv-section">
              <h3 class="pv-section-title">Highlights</h3>
              <ul class="highlight-list">
                {ch.highlights.map((h) => (
                  <li class="highlight-item">
                    <span class="highlight-marker">&rsaquo;</span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>

            {ch.projects.length > 0 && (
              <div class="pv-section">
                <h3 class="pv-section-title">Key Projects</h3>
                <div class="project-list">
                  {ch.projects.map((p) => (
                    <div class:list={['project-card', p.featured && 'project-card--featured']}>
                      <div class="project-card__head">
                        <h4 class="project-card__title">{p.title}</h4>
                        {p.featured && <span class="project-card__star">★</span>}
                      </div>
                      <p class="project-card__desc">{p.desc}</p>
                      {p.metric && <p class="project-card__metric">{p.metric}</p>}
                    </div>
                  ))}
                </div>
              </div>
            )}

            {ch.tech.length > 0 && (
              <div class="pv-section">
                <h3 class="pv-section-title">Technologies</h3>
                <div class="tech-tags">
                  {ch.tech.map((t) => (
                    <span class="tech-tag">{t}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </aside>
  </div>
</section>

<style is:global>
  /* ─── Explorer Section ─── */
  .explorer-section {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  /* ─── Particle Canvas ─── */
  .particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ─── Constellation (Desktop) ─── */
  .constellation {
    display: none;
    position: relative;
    width: 100%;
    height: 100vh;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .constellation { display: block; }
    .mobile-explorer { display: none !important; }
  }

  .constellation__prompt {
    position: absolute;
    bottom: 6%;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-warm-dim);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.7;
    transition: opacity 0.4s;
    pointer-events: none;
  }

  .constellation__prompt.hidden { opacity: 0; }

  /* ─── SVG Lines ─── */
  .lines-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .lines-svg line {
    stroke: rgba(201, 168, 108, 0.25);
    stroke-width: 1;
    transition: stroke 0.5s, stroke-opacity 0.5s, stroke-width 0.5s;
  }

  .lines-svg line.line-active {
    stroke: rgba(201, 168, 108, 0.6);
    stroke-width: 1.5;
  }

  .lines-svg line.line-dimmed {
    stroke-opacity: 0.3;
  }

  /* ─── Constellation Nodes ─── */
  .c-node {
    position: absolute;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    z-index: 2;
    background: none;
    border: none;
    padding: 0;
    outline: none;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s;
  }

  .c-node:focus-visible .c-node__circle {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .c-node__circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 1.5px solid rgba(201, 168, 108, 0.3);
    background: rgba(8, 8, 8, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 0 20px rgba(201, 168, 108, 0.06);
  }

  .c-node__text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .c-node__label {
    font-size: 0.82rem;
    color: var(--color-cream);
    opacity: 0.8;
    white-space: nowrap;
    font-weight: 500;
    transition: opacity 0.3s;
  }

  .c-node__period {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-warm-dim);
    white-space: nowrap;
  }

  /* Center node */
  .c-node--center .c-node__circle {
    width: 80px;
    height: 80px;
    border-width: 2px;
    border-color: rgba(201, 168, 108, 0.5);
  }

  .c-node--center .c-node__text {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  /* Featured node */
  .c-node--featured .c-node__circle {
    width: 72px;
    height: 72px;
    border-color: rgba(201, 168, 108, 0.4);
    box-shadow: 0 0 30px rgba(201, 168, 108, 0.1);
  }

  .c-node--featured .c-node__text {
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Node hover */
  .c-node:hover { transform: translate(-50%, -50%) scale(1.1); }
  .c-node:hover .c-node__circle {
    border-color: rgba(201, 168, 108, 0.5);
    box-shadow: 0 0 40px rgba(201, 168, 108, 0.12);
    background: rgba(201, 168, 108, 0.06);
  }
  .c-node:hover .c-node__label { opacity: 1; }

  /* Node selected */
  .c-node.selected { transform: translate(-50%, -50%) scale(1.15); }
  .c-node.selected .c-node__circle {
    border-color: rgba(201, 168, 108, 0.7);
    box-shadow: 0 0 50px rgba(201, 168, 108, 0.2);
    background: rgba(201, 168, 108, 0.1);
  }
  .c-node.selected .c-node__label { opacity: 1; }

  /* Node dimmed */
  .c-node.dimmed { opacity: 0.35; }
  .c-node.dimmed:hover { opacity: 0.7; }

  /* ─── Panel Overlay ─── */
  .panel-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .panel-overlay.open {
    pointer-events: auto;
    opacity: 1;
  }

  .panel-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }

  .detail-panel {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    width: 42%;
    min-width: 380px;
