---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import PostCard from '../../../components/blog/PostCard.astro';
import { getPublishedPosts, getPostsByTag } from '../../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = new Set<string>();
  posts.forEach((post) => post.data.tags.forEach((tag) => tags.add(tag)));

  return [...tags].map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = await getPostsByTag(tag);
---

<BlogLayout
  title={`Posts tagged "${tag}" | Carlo Perottino`}
  description={`Blog posts about ${tag}.`}
>
  <header class="mb-10">
    <a
      href="/blog/tags"
      class="inline-flex items-center gap-1.5 text-sm text-warm-dim hover:text-accent transition-colors mb-4"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
      All tags
    </a>
    <h1 class="text-3xl font-bold tracking-tight text-cream">
      <span class="text-warm-dim">#</span>{tag}
    </h1>
    <p class="mt-2 text-warm-gray">
      {posts.length} post{posts.length !== 1 ? 's' : ''}
    </p>
  </header>

  <div>
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </div>
</BlogLayout>
