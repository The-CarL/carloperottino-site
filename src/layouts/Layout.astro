---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Carlo Perottino — AI/ML Leader & Builder' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-neutral-950 text-neutral-100 min-h-screen flex items-center justify-center antialiased">
    <slot />
  </body>
</html>
