---
import Layout from './Layout.astro';
import BlogNav from '../components/blog/BlogNav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<Layout title={title} description={description} fullPage>
  <BlogNav />
  <main class="max-w-3xl mx-auto px-6 py-12">
    <slot />
  </main>
  <footer class="border-t border-surface-3/50 mt-16">
    <div class="max-w-3xl mx-auto px-6 py-8 text-center text-sm text-warm-dim">
      &copy; {new Date().getFullYear()} Carlo Perottino
    </div>
  </footer>
</Layout>
